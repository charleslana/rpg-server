{
  "name": "rpg-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint-fix": "eslint . --ext .ts --fix",
    "clear": "rm -rf node_modules && npm i",
    "build": "rm -rf dist && tsc",
    "dev": "node -r dotenv/config -r tsconfig-paths/register ./node_modules/.bin/ts-node-dev --respawn --transpile-only ./src/main.ts",
    "start": "npm run build && NODE_PATH=./dist/src node -r dotenv/config ./dist/src/main.js",
    "migrate": "npx prisma migrate dev --name initial",
    "user-seed": "npx ts-node prisma/seed/userSeed.ts",
    "character-seed": "npx ts-node prisma/seed/characterSeed.ts",
    "seed": "npm run user-seed && npm run character-seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@prisma/client": "^5.9.1",
    "@socket.io/admin-ui": "^0.5.1",
    "bcrypt": "^5.1.1",
    "celebrate": "^15.0.3",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "prisma": "^5.9.1",
    "sanitize-html": "^2.11.0",
    "socket.io": "^4.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/joi": "^17.2.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/sanitize-html": "^2.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "dotenv": "^16.4.4",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
